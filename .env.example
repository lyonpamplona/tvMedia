# ------------------------------------------------------------------ #
# AdSignage — variáveis de ambiente (copie para .env e ajuste)
# ------------------------------------------------------------------ #

# Identificação e modo de execução
APP_NAME=AdSignage
ENVIRONMENT=development
DEBUG=false

# Banco de dados (SQLite por padrão; troque por PostgreSQL em produção)
# Ex.: postgresql+psycopg://user:senha@host:5432/adsignage
DATABASE_URL=sqlite:////app/data/adsignage.db

# Diretórios (dentro do container)
MEDIA_DIR=/app/data/media
FRONTEND_DIR=/app/frontend

# Upload
MAX_UPLOAD_MB=200

# CORS (separe por vírgula; em produção use a origem HTTPS pública)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Processamento opcional de mídia no servidor
MEDIA_PROCESSING_ENABLED=true
IMAGE_MAX_DIMENSION=3840
IMAGE_QUALITY=82
VIDEO_MAX_HEIGHT=1080
VIDEO_CRF=23
VIDEO_PRESET=veryfast
MEDIA_PROCESS_TIMEOUT=1800

# ------------------------- Autenticação -------------------------- #
# Senha única do painel administrativo (TROQUE!)
ADMIN_PASSWORD=admin
# Chave usada para assinar os tokens de sessão (TROQUE por algo longo e secreto)
SECRET_KEY=troque-esta-chave-em-producao
# Validade do token de sessão, em horas
TOKEN_TTL_HOURS=24
# Proteção contra força bruta no login
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300
LOGIN_BLOCK_SECONDS=300

# ----------------------- Plataforma e segurança (P8) -------------- #
# Ative quando a aplicação estiver atrás de proxy HTTPS corretamente configurado.
FORCE_HTTPS=false
SECURITY_HEADERS_ENABLED=true
HSTS_SECONDS=31536000
# Em produção, defina false para ocultar /docs, /redoc e /openapi.json.
API_DOCS_ENABLED=true
# Backups automáticos do SQLite. Para PostgreSQL use ferramenta própria do SGBD.
BACKUP_ENABLED=true
BACKUP_DIR=/app/data/backups
BACKUP_INTERVAL_HOURS=24
BACKUP_KEEP=7
# SSO SAML é opcional e depende de IdP/provedor externo.
SSO_SAML_ENABLED=false
SSO_SAML_METADATA_URL=
SSO_SAML_ENTITY_ID=

# ----------------------- Alertas de telas (P4) -------------------- #
# Envia alerta quando uma TV fica sem heartbeat por alguns minutos.
OFFLINE_ALERT_ENABLED=true
OFFLINE_ALERT_AFTER_MINUTES=5
OFFLINE_ALERT_REPEAT_MINUTES=60
OFFLINE_ALERT_CHECK_SECONDS=60
# Webhook opcional (POST JSON). Deixe vazio para desativar.
OFFLINE_ALERT_WEBHOOK_URL=
# SMTP opcional para e-mail de alerta. Deixe vazio para desativar.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
OFFLINE_ALERT_EMAIL_TO=

# ----------------------- Relatórios BI (P7) ---------------------- #
# Usa as mesmas configurações SMTP acima para enviar PDF+CSV anexados.
REPORT_SCHEDULER_ENABLED=true
REPORT_SCHEDULER_CHECK_SECONDS=300

# ----------------------- Retencao e metricas --------------------- #
# Expurga eventos de proof-of-play mais antigos que N dias (0 = desativado).
PLAY_EVENTS_RETENTION_DAYS=0
RETENTION_CHECK_HOURS=24
# Exposicao de metricas Prometheus em GET /api/metrics (requer token).
METRICS_ENABLED=true

# -------------------------- Agendamento -------------------------- #
# Fuso horário IANA padrão para novas telas (usado na resolução de horários)
DEFAULT_TIMEZONE=America/Sao_Paulo
