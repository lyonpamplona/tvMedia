# Exemplo de configuração. Copie para .env e ajuste conforme necessário.
APP_NAME=AdSignage
DEBUG=false

# Banco de dados (SQLAlchemy). Padrão: SQLite local.
# Exemplo PostgreSQL: postgresql+psycopg://user:senha@host:5432/adsignage
DATABASE_URL=sqlite:///./data/adsignage.db

# Diretórios.
MEDIA_DIR=./data/media
FRONTEND_DIR=../frontend

# Limite de upload em MB.
MAX_UPLOAD_MB=200

# Origens permitidas para CORS (separadas por vírgula). Use * para liberar tudo.
CORS_ORIGINS=*
