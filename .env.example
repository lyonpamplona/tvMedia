# ------------------------------------------------------------------ #
# AdSignage — variáveis de ambiente (copie para .env e ajuste)
# ------------------------------------------------------------------ #

# Identificação e modo de execução
APP_NAME=AdSignage
DEBUG=false

# Banco de dados (SQLite por padrão; troque por PostgreSQL em produção)
# Ex.: postgresql+psycopg://user:senha@host:5432/adsignage
DATABASE_URL=sqlite:////app/data/adsignage.db

# Diretórios (dentro do container)
MEDIA_DIR=/app/data/media
FRONTEND_DIR=/app/frontend

# Upload
MAX_UPLOAD_MB=200

# CORS (separe por vírgula; * libera todas as origens)
CORS_ORIGINS=*

# ------------------------- Autenticação -------------------------- #
# Senha única do painel administrativo (TROQUE!)
ADMIN_PASSWORD=admin
# Chave usada para assinar os tokens de sessão (TROQUE por algo longo e secreto)
SECRET_KEY=troque-esta-chave-em-producao
# Validade do token de sessão, em horas
TOKEN_TTL_HOURS=24

# -------------------------- Agendamento -------------------------- #
# Fuso horário IANA padrão para novas telas (usado na resolução de horários)
DEFAULT_TIMEZONE=America/Sao_Paulo
